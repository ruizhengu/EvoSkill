# MiniMax API Configuration
# MiniMax provides Anthropic API compatibility at https://api.minimax.io/anthropic

# API key (use your MiniMax API key)
ANTHROPIC_API_KEY=sk-ant-dummy1234567890abcdef

# Auth token (required for MiniMax API compatibility)
# Replace with your actual MiniMax auth token
ANTHROPIC_AUTH_TOKEN=sk-cp-your-token-here

# Base URL for Anthropic API compatibility
ANTHROPIC_BASE_URL=https://api.minimax.io/anthropic

# Optional: Phoenix Tracing Configuration
# Set either local endpoint or cloud API key

# Option 1: Local Phoenix server
# PHOENIX_ENDPOINT=http://localhost:6006

# Option 2: Phoenix cloud (Arize)
PHOENIX_ENDPOINT=https://app.phoenix.arize.com
PHOENIX_API_KEY=your-phoenix-api-key

# Enable tracing (set to "true" to enable)
ARIZE_TRACE_ENABLED=true

# Project name for traces
PHOENIX_PROJECT=evoskill
